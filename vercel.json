{
  "version": 2,
  "buildCommand": "cd apps/app && pnpm install --no-frozen-lockfile --retry 3 && pnpm run build",
  "installCommand": "pnpm install --filter @hookahplus/app... --no-frozen-lockfile --retry 3",
  "outputDirectory": "apps/app/.next",
  "framework": "nextjs",
  "functions": {
    "apps/app/app/api/payments/live-test/route.ts": {
      "maxDuration": 30
    },
    "apps/app/app/api/stripe-health/route.ts": {
      "maxDuration": 15
    }
  },
  "regions": ["iad1"],
  "env": {
    "FORCE_REBUILD": "true",
    "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
    "NPM_CONFIG_FETCH_RETRIES": "3",
    "NPM_CONFIG_FETCH_RETRY_FACTOR": "2"
  }
}
