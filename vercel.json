{
  "version": 2,
  "buildCommand": "npm install --legacy-peer-deps && cd apps/app && npm install --legacy-peer-deps && npm run vercel-build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": "nextjs",
  "builds": [
    {
      "src": "apps/app/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "outputDirectory": "apps/app/.next",
  "functions": {
    "apps/app/app/api/**/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "env": {
    "NODE_VERSION": "18"
  }
}
