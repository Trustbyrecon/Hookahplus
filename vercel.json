{
  "version": 2,
  "rootDirectory": "apps/app",
  "buildCommand": "npm install && npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/payments/live-test/route.ts": {
      "maxDuration": 30
    },
    "app/api/stripe-health/route.ts": {
      "maxDuration": 15
    }
  },
  "regions": ["iad1"],
  "env": {
    "FORCE_REBUILD": "true"
  }
}
