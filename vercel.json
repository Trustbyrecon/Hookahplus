{
  "version": 2,
  "builds": [
    {
      "src": "apps/site/package.json",
      "use": "@vercel/next",
      "config": {
        "buildCommand": "pnpm build --filter=@hookahplus/site",
        "installCommand": "pnpm install --no-frozen-lockfile",
        "outputDirectory": "apps/site/.next"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/site/$1"
    }
  ]
}