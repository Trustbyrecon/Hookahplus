{
  "version": 2,
  "builds": [
    {
      "src": "apps/app/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "apps/guest/package.json", 
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "apps/site/package.json",
      "use": "@vercel/next", 
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/app/(.*)",
      "dest": "/apps/app/$1"
    },
    {
      "src": "/guest/(.*)",
      "dest": "/apps/guest/$1"
    },
    {
      "src": "/site/(.*)",
      "dest": "/apps/site/$1"
    }
  ],
  "functions": {
    "apps/app/app/api/**/route.ts": {
      "maxDuration": 10
    },
    "apps/guest/app/api/**/route.ts": {
      "maxDuration": 30
    },
    "apps/site/app/api/**/route.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "FORCE_REBUILD": "true",
    "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
    "NPM_CONFIG_FETCH_RETRIES": "3",
    "NPM_CONFIG_FETCH_RETRY_FACTOR": "2"
  },
  "build": {
    "env": {
      "NPM_CONFIG_PACKAGE_MANAGER": "npm"
    }
  },
  "redirects": [
    {
      "source": "/feat-guests-cart/:path*",
      "destination": "https://hookahplus-app-prod.vercel.app/:path*",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}