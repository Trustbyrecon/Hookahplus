{
  "version": 2,
  "buildCommand": "cd apps/app && pnpm install && pnpm run build",
  "installCommand": "pnpm install --filter @hookahplus/app...",
  "outputDirectory": "apps/app/.next",
  "framework": "nextjs",
  "functions": {
    "apps/app/app/api/payments/live-test/route.ts": {
      "maxDuration": 30
    },
    "apps/app/app/api/stripe-health/route.ts": {
      "maxDuration": 15
    }
  },
  "regions": ["iad1"],
  "env": {
    "FORCE_REBUILD": "true"
  }
}
