{
  "version": 2,
  "builds": [
    {
      "src": "apps/admin/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "apps/dashboard/package.json", 
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "apps/preorder/package.json",
      "use": "@vercel/next", 
      "config": {
        "distDir": ".next"
      }
    },
    {
      "src": "apps/app/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/admin/(.*)",
      "dest": "/apps/admin/$1"
    },
    {
      "src": "/dashboard/(.*)", 
      "dest": "/apps/dashboard/$1"
    },
    {
      "src": "/preorder/(.*)",
      "dest": "/apps/preorder/$1"
    },
    {
      "src": "/operator/(.*)",
      "dest": "/apps/app/app/operator/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/app/$1"
    }
  ],
  "functions": {
    "apps/app/app/api/payments/live-test/route.ts": {
      "maxDuration": 30
    },
    "apps/app/app/api/stripe-health/route.ts": {
      "maxDuration": 15
    },
    "apps/app/app/api/**/route.ts": {
      "maxDuration": 10
    }
  },
  "regions": ["iad1"],
  "env": {
    "FORCE_REBUILD": "true",
    "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
    "NPM_CONFIG_FETCH_RETRIES": "3",
    "NPM_CONFIG_FETCH_RETRY_FACTOR": "2"
  },
  "build": {
    "env": {
      "NPM_CONFIG_PACKAGE_MANAGER": "npm"
    }
  },
  "redirects": [
    {
      "source": "/feat-guests-cart/:path*",
      "destination": "https://hookahplus-app-prod.vercel.app/:path*",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}