{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @hookahplus/app run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "builds": [
    {
      "src": "apps/app/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "outputDirectory": "apps/app/.next"
}
