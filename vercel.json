{
  "version": 2,
  "buildCommand": "cd apps/app && pnpm install --no-frozen-lockfile && pnpm run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "builds": [
    {
      "src": "apps/app/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/app/$1"
    }
  ],
  "functions": {
    "apps/app/app/api/payments/live-test/route.ts": {
      "maxDuration": 30
    },
    "apps/app/app/api/stripe-health/route.ts": {
      "maxDuration": 15
    }
  },
  "regions": ["iad1"],
  "env": {
    "FORCE_REBUILD": "true"
  }
}
