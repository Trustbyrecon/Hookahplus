{
  "version": 2,
  "env": {
    "FORCE_REBUILD": "true",
    "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
    "NPM_CONFIG_FETCH_RETRIES": "3",
    "NPM_CONFIG_FETCH_RETRY_FACTOR": "2",
    "NEXT_PUBLIC_SITE_URL": "https://hookahplus.net",
    "NEXT_PUBLIC_APP_URL": "https://hookahplus-app-prod.vercel.app",
    "NEXT_PUBLIC_GUEST_URL": "https://hookahplus-guest-prod.vercel.app"
  },
  "build": {
    "env": {
      "NPM_CONFIG_PACKAGE_MANAGER": "npm"
    }
  },
  "redirects": [
    {
      "source": "/app/:path*",
      "destination": "https://hookahplus-app-prod.vercel.app/:path*",
      "permanent": false
    },
    {
      "source": "/guest/:path*",
      "destination": "https://hookahplus-guest-prod.vercel.app/:path*",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}