{
  "version": 2,
  "name": "hookahplus",
  "alias": ["hookahplus.net", "www.hookahplus.net"],
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://hookahplus.net"
  },
  "functions": {
    "apps/web/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/www/(.*)",
      "destination": "https://hookahplus.net/$1",
      "permanent": true
    }
  ]
}
