# App Environment Configuration
# Aliethia-Enhanced: Trust Compounds for Staff Operations and Community Management
# Copy this to .env.local for local development
# Set these in Vercel → Settings → Environment Variables

# === CORE TRUST COMPOUNDS ===
# These variables establish trust signals for staff operations and community management

# Database Configuration
# PostgreSQL connection string (Supabase or local)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres
# For local SQLite (development only):
# DATABASE_URL="file:./dev.db"

# Supabase - Database Trust Compound
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Stripe - Payment Trust Compound
# IMPORTANT: For demo mode, use test keys (sk_test_...) only!
# Live keys (sk_live_...) are NOT allowed in demo mode and will be rejected.
STRIPE_SECRET_KEY=sk_test_placeholder
# Optional: Demo-specific test key (takes priority in demo mode)
# If STRIPE_SECRET_KEY is a live key, set this for demo mode:
# STRIPE_TEST_SECRET_KEY=sk_test_your_demo_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_placeholder

# Sentry - Error Tracking
# Get your DSN from: https://sentry.io/settings/[org]/projects/[project]/keys/
NEXT_PUBLIC_SENTRY_DSN=
# Optional: For release tracking and source maps
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-auth-token

# Caching - API Response Caching
# Vercel KV (recommended): Automatically set when you connect KV database in Vercel Dashboard
# KV_REST_API_URL=https://your-kv-database.upstash.io
# KV_REST_API_TOKEN=your-kv-token
# KV_REST_API_READ_ONLY_TOKEN=your-read-only-token (optional)
# 
# Alternative: Standard Redis URL (fallback if KV not available)
# REDIS_URL=redis://localhost:6379
# 
# Disable cache in development (set to 'true' to disable)
# DISABLE_CACHE=false

# Logging - Structured Logging (Pino)
# Log level: debug, info, warn, error (default: info in production, debug in development)
LOG_LEVEL=info
# Enable structured JSON logging (default: true in production)
STRUCTURED_LOGGING=true

# Pino Transports - Log Forwarding
# File Transport (optional)
# PINO_FILE_ENABLED=false
# PINO_FILE_PATH=./logs/app.log
# PINO_FILE_LEVEL=info

# Datadog Transport (optional)
# DATADOG_API_KEY=your_datadog_api_key
# DATADOG_SITE=us1
# DATADOG_SERVICE=hookahplus-app
# DATADOG_LOG_LEVEL=info
# DATADOG_HOSTNAME=your-hostname

# LogRocket Transport (optional)
# LOGROCKET_APP_ID=your_logrocket_app_id
# LOGROCKET_LOG_LEVEL=warn

# Custom HTTP Transport (optional)
# PINO_HTTP_ENABLED=false
# PINO_HTTP_URL=https://your-log-endpoint.com/api/logs
# PINO_HTTP_METHOD=POST
# PINO_HTTP_LEVEL=info
# PINO_HTTP_HEADERS={"Authorization":"Bearer token"}

# Database Connection Pooling
# Maximum number of connections in the pool (default: 10)
DATABASE_POOL_MAX=10
# Minimum number of connections to keep alive (default: 2)
DATABASE_POOL_MIN=2
# Connection timeout in milliseconds (default: 10000)
DATABASE_POOL_TIMEOUT=10000
# Idle timeout in milliseconds (default: 30000)
DATABASE_POOL_IDLE_TIMEOUT=30000

# API Versioning
# Default API version (v1, v2, latest)
# API_DEFAULT_VERSION=v1

# Cross-App Trust Compounds - Community Connection Signals
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_GUEST_URL=https://your-guest.vercel.app

