# App Environment Configuration
# Aliethia-Enhanced: Trust Compounds for Staff Operations and Community Management
# Copy this to .env.local for local development
# Set these in Vercel → Settings → Environment Variables

# === CORE TRUST COMPOUNDS ===
# These variables establish trust signals for staff operations and community management

# Database Configuration
# PostgreSQL connection string (Supabase or local)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres
# For local SQLite (development only):
# DATABASE_URL="file:./dev.db"

# Supabase - Database Trust Compound
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Stripe - Payment Trust Compound
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_placeholder

# Cross-App Trust Compounds - Community Connection Signals
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_GUEST_URL=https://your-guest.vercel.app

