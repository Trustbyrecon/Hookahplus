// Network-wide customer profiles (Hookah+ Network Identity Layer)
model NetworkProfile {
  id           String   @id @default(cuid())
  hid          String   @unique // Hookah+ ID (portable identifier)
  phoneHash    String?  @map("phone_hash") // SHA256 hash of phone
  emailHash    String?  @map("email_hash") // SHA256 hash of email
  consentLevel String   @default("shadow") @map("consent_level") // shadow | claimed | network_shared
  tier         String? // Current loyalty tier
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  preferences NetworkPreference?
  badges      NetworkBadge[]
  sessions    NetworkSession[]
  notes       NetworkSessionNote[]
  piiLinks    NetworkPIILink[]
  sessionsRef Session[] // Sessions linked to this profile

  @@index([hid], map: "idx_network_profile_hid")
  @@index([phoneHash], map: "idx_network_profile_phone_hash")
  @@index([emailHash], map: "idx_network_profile_email_hash")
  @@index([consentLevel], map: "idx_network_profile_consent")
  @@map("network_profiles")
}

model NetworkPreference {
  id           String   @id @default(cuid())
  hid          String   @unique
  topFlavors   Json?    @map("top_flavors") // Array of favorite flavors
  flavorVector String?  @map("flavor_vector") // ML embedding (JSON string)
  devicePrefs  Json?    @map("device_prefs") // Device preferences
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile NetworkProfile @relation(fields: [hid], references: [hid], onDelete: Cascade)

  @@index([hid], map: "idx_network_preference_hid")
  @@map("network_preferences")
}

model NetworkBadge {
  id        String   @id @default(cuid())
  hid       String
  badgeCode String   @map("badge_code")
  awardedAt DateTime @default(now()) @map("awarded_at") @db.Timestamptz(6)
  meta      Json? // Additional metadata

  profile NetworkProfile @relation(fields: [hid], references: [hid], onDelete: Cascade)

  @@unique([hid, badgeCode], map: "idx_network_badge_unique")
  @@index([hid], map: "idx_network_badge_hid")
  @@index([badgeCode], map: "idx_network_badge_code")
  @@map("network_badges")
}

model NetworkSession {
  id         String    @id // Use sessionId-based ID (NS-{sessionId})
  hid        String
  sessionId  String    @unique @map("session_id") // Link to Session.id (unique)
  loungeId   String    @map("lounge_id")
  startTs    DateTime? @map("start_ts") @db.Timestamptz(6)
  endTs      DateTime? @map("end_ts") @db.Timestamptz(6)
  items      Json? // Order items
  spendCents Int?      @map("spend_cents")
  posRef     String?   @map("pos_ref")
  rating     Int? // Customer rating (1-5)

  profile NetworkProfile @relation(fields: [hid], references: [hid], onDelete: Cascade)

  @@index([hid], map: "idx_network_session_hid")
  @@index([sessionId], map: "idx_network_session_session_id")
  @@index([loungeId], map: "idx_network_session_lounge_id")
  @@map("network_sessions")
}

model NetworkSessionNote {
  id         String   @id @default(cuid())
  hid        String
  noteId     String   @unique @map("note_id") // Link to SessionNote.id
  loungeId   String   @map("lounge_id")
  staffId    String?  @map("staff_id")
  noteText   String   @map("note_text")
  shareScope String   @default("lounge") @map("share_scope") // lounge | network
  tags       Json? // Behavioral tags
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profile NetworkProfile @relation(fields: [hid], references: [hid], onDelete: Cascade)

  @@index([hid], map: "idx_network_session_note_hid")
  @@index([loungeId], map: "idx_network_session_note_lounge_id")
  @@index([shareScope], map: "idx_network_session_note_scope")
  @@map("network_session_notes")
}

model NetworkPIILink {
  id         String    @id @default(cuid())
  hid        String
  piiType    String    @map("pii_type") // phone | email | qr_token
  piiHash    String    @map("pii_hash") // Hashed identifier
  verified   Boolean   @default(false)
  verifiedAt DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile NetworkProfile @relation(fields: [hid], references: [hid], onDelete: Cascade)

  @@unique([piiType, piiHash], map: "idx_network_pii_unique")
  @@index([hid], map: "idx_network_pii_hid")
  @@index([piiHash], map: "idx_network_pii_hash")
  @@map("network_pii_links")
}

// Apple Wallet (PassKit) device registrations for pass updates.
// Stored server-side so devices can poll for updated passes and receive push updates later.
model PasskitRegistration {
  id                    String   @id @default(cuid())
  passTypeIdentifier    String   @map("pass_type_identifier")
  serialNumber          String   @map("serial_number")
  deviceLibraryIdentifier String @map("device_library_identifier")
  pushToken             String   @map("push_token")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([deviceLibraryIdentifier, passTypeIdentifier, serialNumber], map: "idx_passkit_reg_unique")
  @@index([serialNumber], map: "idx_passkit_reg_serial")
  @@index([deviceLibraryIdentifier], map: "idx_passkit_reg_device")
  @@map("passkit_registrations")
}

// LaunchPad SetupSession - Anonymous onboarding sessions
model SetupSession {
  id              String    @id @default(cuid())
  token           String    @unique
  setupLink       String?   @map("setup_link") // Auto-generated: /launchpad?token={token}
  status          String    @default("draft") // draft | in_progress | completed | activated | expired | abandoned
  progress        Json // LaunchPadProgress type
  stripeCheckoutSessionId String? @unique @map("stripe_checkout_session_id")
  loungeId        String?   @unique @map("lounge_id")
  organizationId  String?   @map("organization_id") @db.Uuid
  organizationSlug String?  @map("organization_slug")
  multiLocationEnabled Boolean @default(false) @map("multi_location_enabled")
  locationDrafts  Json?     @map("location_drafts")
  activatedLoungeIds String[] @default([]) @map("activated_lounge_ids")
  source          String? // "manychat" | "web" | "direct"
  manychatUserId  String?   @map("manychat_user_id")
  instagramHandle String?   @map("instagram_handle")
  prefillData     Json?     @map("prefill_data") // ManyChat collected data
  userId          String?   @map("user_id") // Set at Go Live
  leadId          String?   @map("lead_id") // Link to Soft Lead (auto-created)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastActivityAt  DateTime? @map("last_activity_at") @db.Timestamptz(6) // Track for abandonment detection

  @@index([token], map: "idx_setup_session_token")
  @@index([stripeCheckoutSessionId], map: "idx_setup_session_stripe_checkout_session_id")
  @@index([expiresAt], map: "idx_setup_session_expires")
  @@index([loungeId], map: "idx_setup_session_lounge_id")
  @@index([organizationId], map: "idx_setup_session_organization_id")
  @@index([organizationSlug], map: "idx_setup_session_organization_slug")
  @@index([source], map: "idx_setup_session_source")
  @@index([status], map: "idx_setup_session_status")
  @@index([lastActivityAt], map: "idx_setup_session_last_activity")
  @@map("setup_sessions")
}
