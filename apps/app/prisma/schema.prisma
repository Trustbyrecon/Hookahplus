generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String         @id @default(cuid())
  externalRef         String?
  source              SessionSource
  trustSignature      String
  state               SessionState   @default(PENDING)
  customerPhone       String?
  flavorMix           Json?
  loungeId            String
  version             Int            @default(1)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  tableId             String?
  customerRef         String?
  flavor              String?
  priceCents          Int?           @default(3000)
  edgeCase            String?
  edgeNote            String?
  assignedBOHId       String?
  assignedFOHId       String?
  startedAt           DateTime?      @db.Timestamptz(6)
  endedAt             DateTime?      @db.Timestamptz(6)
  durationSecs        Int?
  paymentIntent       String?
  paymentStatus       String?
  orderItems          String?
  posMode             String?
  timerDuration       Int?
  timerStartedAt      DateTime?      @db.Timestamptz(6)
  timerPausedAt       DateTime?      @db.Timestamptz(6)
  timerPausedDuration Int?
  timerStatus         String?
  zone                String?
  fohUserId           String?
  specialRequests     String?
  tableNotes          String?
  qrCodeUrl           String?
  sessionStateV1      String?        @map("session_state_v1")
  paused              Boolean?       @default(false)
  tenantId            String?        @map("tenant_id") @db.Uuid
  preorderId          String?        @map("preorder_id")
  loungeConfigVersion Int?           @map("lounge_config_version")
  seatId              String?        @map("seat_id")
  zoneId              String?        @map("zone_id")
  stage               String?        @map("nan_stage")
  action              String?        @map("nan_action")
  preorder            PreOrder?      @relation(fields: [preorderId], references: [id])
  seat                Seat?          @relation(fields: [seatId], references: [id])
  tenant              Tenant?        @relation(fields: [tenantId], references: [id], onUpdate: NoAction)
  zoneRelation        Zone?          @relation("SessionZone", fields: [zoneId], references: [id])
  SessionEvent        SessionEvent[]
  deliveries          Delivery[]
  orders              Order[]
  payments            Payment[]
  notes               SessionNote[]

  @@unique([loungeId, externalRef])
  @@index([preorderId])
  @@index([seatId])
  @@index([zoneId])
  @@index([loungeConfigVersion])
  @@index([loungeId, state])
  @@index([createdAt], map: "idx_session_created_at")
  @@index([createdAt, source], map: "idx_session_created_at_source")
  @@index([createdAt, state], map: "idx_session_created_at_state")
  @@index([customerRef], map: "idx_session_customer_ref")
  @@index([externalRef], map: "idx_session_external_ref")
  @@index([loungeId], map: "idx_session_lounge_id")
  @@index([paused], map: "idx_session_paused")
  @@index([state], map: "idx_session_state")
  @@index([sessionStateV1], map: "idx_session_state_v1")
  @@index([tableId], map: "idx_session_table_id")
  @@map("Session")
}

model Tenant {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  createdAt   DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  sessions    Session[]
  memberships Membership[]
  menu_files  MenuFile[]
  payments    Payment[]
  events      ReflexEvent[]

  @@index([createdAt], map: "idx_tenants_created_at")
  @@index([name], map: "idx_tenants_name")
  @@map("tenants")
}

model Membership {
  userId    String    @map("user_id") @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  role      role      @default(viewer)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, tenantId])
  @@index([role], map: "idx_memberships_role")
  @@index([tenantId], map: "idx_memberships_tenant_id")
  @@index([userId], map: "idx_memberships_user_id")
  @@index([userId, tenantId], map: "idx_memberships_user_tenant")
  @@map("memberships")
}

model Payment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  sessionId      String?   @map("session_id")
  stripeChargeId String?   @unique @map("stripe_charge_id")
  amountCents    Int       @map("amount_cents")
  status         String    @default("pending")
  paidAt         DateTime? @map("paid_at") @db.Timestamptz(6)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  session        Session?  @relation(fields: [sessionId], references: [id], onUpdate: NoAction)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt], map: "idx_payments_created_at")
  @@index([status], map: "idx_payments_status")
  @@index([tenantId], map: "idx_payments_tenant_id")
  @@map("payments")
}

model ReflexEvent {
  id                  String   @id @default(cuid())
  type                String
  source              String   @default("ui")
  sessionId           String?
  paymentIntent       String?
  payload             String?
  payloadHash         String?
  userAgent           String?
  ip                  String?
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  ctaSource           String?
  ctaType             String?
  referrer            String?
  campaignId          String?
  metadata            String?
  trust_event_type_v1 String?
  tenantId            String?  @map("tenant_id") @db.Uuid
  trustEventTypeV1    String?
  tenant              Tenant?  @relation(fields: [tenantId], references: [id], onUpdate: NoAction)

  @@index([createdAt, type], map: "idx_reflex_event_created_at_type")
  @@index([trust_event_type_v1], map: "idx_reflex_event_trust_type_v1")
  @@index([createdAt(sort: Desc)], map: "idx_reflex_events_created")
  @@index([type, createdAt], map: "idx_reflex_events_type_createdat")
  @@map("reflex_events")
}

model MenuFile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId        String?   @map("lead_id")
  fileName      String    @map("file_name")
  fileUrl       String    @map("file_url")
  fileType      String    @map("file_type")
  fileSize      Int       @map("file_size")
  uploadedAt    DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  processedAt   DateTime? @map("processed_at") @db.Timestamptz(6)
  status        String    @default("pending")
  extractedData Json?     @map("extracted_data")
  tenantId      String?   @map("tenant_id") @db.Uuid
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  tenants       Tenant?   @relation(fields: [tenantId], references: [id], onUpdate: NoAction)

  @@index([leadId], map: "idx_menu_files_lead_id")
  @@index([status], map: "idx_menu_files_status")
  @@index([tenantId], map: "idx_menu_files_tenant_id")
  @@index([uploadedAt], map: "idx_menu_files_uploaded_at")
  @@map("menu_files")
}

model DriftEvent {
  id              String    @id @default(cuid())
  session_id      String?
  drift_reason_v1 String?
  severity        String?
  details         Json?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_drift_event_created")
  @@index([drift_reason_v1], map: "idx_drift_event_reason_v1")
  @@index([session_id], map: "idx_drift_event_session")
  @@map("DriftEvent")
}

model TaxonomyUnknown {
  id                String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  enum_type         String
  raw_label         String
  suggested_mapping String?
  count             Int?      @default(1)
  example_event_id  String?
  example_payload   Json?
  first_seen        DateTime? @default(now()) @db.Timestamptz(6)
  last_seen         DateTime? @default(now()) @db.Timestamptz(6)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([enum_type, raw_label])
  @@index([count(sort: Desc)], map: "idx_taxonomy_unknown_count")
  @@index([last_seen(sort: Desc)], map: "idx_taxonomy_unknown_last_seen")
  @@index([enum_type], map: "idx_taxonomy_unknown_type")
  @@map("TaxonomyUnknown")
}

model Order {
  id                  String       @id @default(cuid())
  sessionId           String       @map("session_id")
  type                String
  status              String       @default("PENDING")
  priceSnapshot       String?      @map("price_snapshot")
  specialInstructions String?      @map("special_instructions")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  servedAt            DateTime?    @map("served_at")
  delivery            Delivery?
  events              OrderEvent[]
  items               OrderItem[]
  session             Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status, createdAt])
  @@index([createdAt(sort: Desc)], map: "idx_orders_created")
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String  @map("order_id")
  itemType   String  @map("item_type")
  itemId     String? @map("item_id")
  name       String
  quantity   Int     @default(1)
  priceCents Int     @map("price_cents")
  metadata   String?
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  eventType String   @map("event_type")
  staffId   String?  @map("staff_id")
  metadata  String?
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_events")
}

model PreOrder {
  id            String    @id @default(cuid())
  loungeId      String    @map("lounge_id")
  guestHandle   String?   @map("guest_handle")
  qrCode        String?   @map("qr_code")
  status        String    @default("PENDING")
  scheduledTime DateTime? @map("scheduled_time")
  partySize     Int       @map("party_size")
  flavorMixJson String?   @map("flavor_mix_json")
  basePrice     Int       @map("base_price")
  lockedPrice   Int?      @map("locked_price")
  metadata      String?
  sessionId     String?   @map("session_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  convertedAt   DateTime? @map("converted_at")
  expiresAt     DateTime? @map("expires_at")
  sessions      Session[]

  @@index([loungeId, status])
  @@map("preorders")
}

model Delivery {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  orderId     String   @unique @map("order_id")
  deliveredBy String   @map("delivered_by")
  deliveredAt DateTime @default(now()) @map("delivered_at")
  notes       String?
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([deliveredBy, deliveredAt])
  @@map("deliveries")
}

model SessionNote {
  id              String               @id @default(cuid())
  sessionId       String               @map("session_id")
  noteType        String               @map("note_type")
  text            String
  sentiment       String?
  loyaltyImpact   Int?                 @map("loyalty_impact")
  behavioralTags  String?              @map("behavioral_tags")
  createdBy       String               @map("created_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  loyaltyBindings LoyaltyNoteBinding[]
  session         Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([noteType, createdAt])
  @@map("session_notes")
}

model LoyaltyProfile {
  id                String               @id @default(cuid())
  loungeId          String               @map("lounge_id")
  guestKey          String               @map("guest_key")
  cumulativeSpend   Int                  @default(0) @map("cumulative_spend")
  visitCount        Int                  @default(0) @map("visit_count")
  lastVisitAt       DateTime?            @map("last_visit_at")
  preferenceSummary String?              @map("preference_summary")
  trustScore        Int                  @default(50) @map("trust_score")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  noteBindings      LoyaltyNoteBinding[]

  @@unique([loungeId, guestKey])
  @@index([loungeId])
  @@map("loyalty_profiles")
}

model LoyaltyNoteBinding {
  id               String         @id @default(cuid())
  loyaltyProfileId String         @map("loyalty_profile_id")
  sessionNoteId    String         @map("session_note_id")
  loyaltyProfile   LoyaltyProfile @relation(fields: [loyaltyProfileId], references: [id], onDelete: Cascade)
  sessionNote      SessionNote    @relation(fields: [sessionNoteId], references: [id], onDelete: Cascade)

  @@unique([loyaltyProfileId, sessionNoteId])
  @@map("loyalty_note_bindings")
}

model Zone {
  id           String    @id @default(cuid())
  loungeId     String    @map("lounge_id")
  name         String
  zoneType     String    @map("zone_type")
  displayOrder Int       @default(0) @map("display_order")
  metadata     String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  sessions     Session[] @relation("SessionZone")
  seats        Seat[]

  @@index([loungeId])
  @@map("zones")
}

model Seat {
  id              String    @id @default(cuid())
  loungeId        String    @map("lounge_id")
  zoneId          String    @map("zone_id")
  tableId         String    @unique @map("table_id")
  name            String?
  capacity        Int
  coordinates     String?
  qrEnabled       Boolean   @default(true) @map("qr_enabled")
  status          String    @default("ACTIVE")
  priceMultiplier Float     @default(1.0) @map("price_multiplier")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  sessions        Session[]
  zone            Zone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([loungeId, zoneId])
  @@map("seats")
}

model Station {
  id          String   @id @default(cuid())
  loungeId    String   @map("lounge_id")
  name        String
  stationType String   @map("station_type")
  zoneId      String?  @map("zone_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([loungeId])
  @@map("stations")
}

model Flavor {
  id          String   @id @default(cuid())
  loungeId    String?  @map("lounge_id")
  name        String
  description String?
  tags        String?
  isPremium   Boolean  @default(false) @map("is_premium")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([loungeId])
  @@map("flavors")
}

model MixTemplate {
  id         String   @id @default(cuid())
  loungeId   String   @map("lounge_id")
  name       String
  flavorIds  String   @map("flavor_ids")
  priceCents Int?     @map("price_cents")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([loungeId])
  @@map("mix_templates")
}

model PricingRule {
  id          String    @id @default(cuid())
  loungeId    String    @map("lounge_id")
  ruleType    String    @map("rule_type")
  ruleConfig  String    @map("rule_config")
  version     Int       @default(1)
  isActive    Boolean   @default(true) @map("is_active")
  effectiveAt DateTime  @default(now()) @map("effective_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([loungeId, isActive, effectiveAt])
  @@map("pricing_rules")
}

model LoungeConfig {
  id          String   @id @default(cuid())
  loungeId    String   @unique @map("lounge_id")
  configData  String   @map("config_data")
  version     Int      @default(1)
  effectiveAt DateTime @default(now()) @map("effective_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([loungeId, version])
  @@map("lounge_configs")
}

model SyncBacklog {
  id          String    @id @default(cuid())
  deviceId    String    @map("device_id")
  loungeId    String    @map("lounge_id")
  operation   String
  payload     String
  status      String    @default("PENDING")
  retryCount  Int       @default(0) @map("retry_count")
  lastAttempt DateTime? @map("last_attempt")
  createdAt   DateTime  @default(now()) @map("created_at")
  syncedAt    DateTime? @map("synced_at")

  @@index([deviceId, status])
  @@index([loungeId, status, createdAt])
  @@map("sync_backlog")
}

model AuditLog {
  id         String   @id @default(cuid())
  loungeId   String?  @map("lounge_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  changes    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([loungeId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Award {
  id        String   @id
  profileId String
  badgeId   String
  venueId   String?
  progress  Int      @default(100)
  awardedAt DateTime @default(now())
  awardedBy String?
  revoked   Boolean  @default(false)
  Badge     Badge    @relation(fields: [badgeId], references: [id])

  @@index([badgeId], map: "idx_award_badge_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Badge {
  id     String  @id
  label  String
  scope  String
  rule   Json
  active Boolean @default(true)
  Award  Award[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Event {
  id        String   @id
  ts        DateTime @default(now())
  type      String
  profileId String
  venueId   String?
  comboHash String?
  staffId   String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SessionEvent {
  id          String   @id
  sessionId   String
  type        String
  payloadSeal String
  data        Json
  createdAt   DateTime @default(now())
  Session     Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model SettlementReconciliation {
  id             String    @id @default(cuid())
  stripeChargeId String?   @map("stripe_charge_id")
  posTicketId    String?   @map("pos_ticket_id")
  sessionId      String?   @map("session_id")
  amount         Int?      @map("amount")
  currency       String?   @map("currency")
  status         String    @default("pending") @map("status")
  matchedAt      DateTime? @map("matched_at") @db.Timestamptz(6)
  reconciledAt   DateTime? @map("reconciled_at") @db.Timestamptz(6)
  repairRunId    String?   @map("repair_run_id")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status], map: "idx_settlement_reconciliation_status")
  @@index([stripeChargeId], map: "idx_settlement_reconciliation_stripe_charge_id")
  @@index([posTicketId], map: "idx_settlement_reconciliation_pos_ticket_id")
  @@index([sessionId], map: "idx_settlement_reconciliation_session_id")
  @@map("settlement_reconciliation")
}

model PosTicket {
  id             String   @id @default(cuid())
  ticketId       String   @unique @map("ticket_id")
  stripeChargeId String?  @map("stripe_charge_id")
  sessionId      String?  @map("session_id")
  amountCents    Int?     @map("amount_cents")
  currency       String?  @map("currency")
  status         String   @default("pending") @map("status")
  posSystem      String?  @map("pos_system")
  items          String?  @map("items")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([ticketId], map: "idx_pos_ticket_ticket_id")
  @@index([stripeChargeId], map: "idx_pos_ticket_stripe_charge_id")
  @@index([sessionId], map: "idx_pos_ticket_session_id")
  @@index([status], map: "idx_pos_ticket_status")
  @@map("pos_tickets")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ghostlog {
  id         BigInt    @id @default(autoincrement())
  venue_id   String?   @db.Uuid
  session_id String?   @db.Uuid
  actor      String?
  event      String
  meta       Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refills {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id   String    @db.Uuid
  venue_id     String    @db.Uuid
  requested_at DateTime? @default(now()) @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)
  sessions     sessions  @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  venues       venues    @relation(fields: [venue_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reservations {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venue_id          String              @db.Uuid
  table_id          String
  status            reservation_status? @default(HOLD)
  payment_intent_id String?
  hold_amount_cents Int?                @default(1000)
  window_minutes    Int?                @default(15)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  venues            venues              @relation(fields: [venue_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sessions {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venue_id            String          @db.Uuid
  table_id            String
  tier                String
  flavors             String[]        @default([])
  status              session_status? @default(PENDING)
  started_at          DateTime?       @db.Timestamptz(6)
  ends_at             DateTime?       @db.Timestamptz(6)
  price_lookup_key    String?
  payment_intent_id   String?
  checkout_session_id String?
  created_by          String?         @db.Uuid
  created_at          DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?       @db.Timestamptz(6)
