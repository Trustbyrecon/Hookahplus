// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id             String      @id @default(cuid())
  tableId        String
  customerRef    String?
  flavor         String?
  priceCents     Int
  state          String       @default("NEW")
  edgeCase       String?     // 'EQUIPMENT_ISSUE', 'CUSTOMER_NOT_FOUND', 'PAYMENT_FAILED', 'HEALTH_SAFETY', 'OTHER'
  edgeNote       String?
  assignedBOHId  String?
  assignedFOHId  String?
  startedAt      DateTime?   // set when state -> ACTIVE
  endedAt        DateTime?   // set when state -> COMPLETED/CANCELLED
  durationSecs   Int?        // compute on complete
  paymentIntent  String?     // Stripe PI id
  paymentStatus  String?     // requires "succeeded" to complete
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  // Timer fields
  timerDuration      Int?     // in minutes
  timerStartedAt     DateTime?
  timerPausedAt      DateTime?
  timerPausedDuration Int?    // total paused time in seconds
  timerStatus        String?  // 'stopped' | 'running' | 'paused' | 'completed'

  // New fields for Pre-Order flow
  zone            String?     // 'VIP', 'Standard', 'Patio', etc.
  fohUserId       String?     // FOH staff assigned to this session
  posMode         String?     // 'shadow', 'mirror', 'ticket'
  orderItems      String?     // JSON string of ordered items with quantities
  specialRequests String?     // Customer special requests
  tableNotes      String?     // Notes specific to this table/session

  @@map("sessions")
}

// Enums replaced with string fields for SQLite compatibility

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  roles     String   // Comma-separated roles: "BOH,FOH,MANAGER,ADMIN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SessionTransition {
  id          String   @id @default(cuid())
  sessionId   String
  fromState   String
  toState     String
  transition  String
  userId      String
  note        String?
  createdAt   DateTime @default(now())

  @@map("session_transitions")
}

model OrgSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String?  // 'pos', 'menu', 'timing', 'ui'
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("org_settings")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  icon        String?  // Icon name or URL
  color       String?  // Hex color code
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  items       Item[]

  @@map("categories")
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  categoryId  String
  isActive    Boolean  @default(true)
  displayOrder Int     @default(0)
  imageUrl    String?
  allergens   String   // Comma-separated allergen strings
  isPopular   Boolean  @default(false)
  prepTime    Int?     // Prep time in minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  category    Category @relation(fields: [categoryId], references: [id])

  @@map("items")
}