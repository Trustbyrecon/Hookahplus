// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SessionSource {
  QR
  RESERVE
  WALK_IN
  LEGACY_POS
}

enum SessionState {
  PENDING
  ACTIVE
  PAUSED
  CLOSED
  CANCELED
}

enum Role {
  owner
  admin
  staff
  viewer
}

model Session {
  id             String        @id @default(cuid())
  externalRef    String? // qrToken | reservationId | stripeCheckoutId
  source         SessionSource // QR | RESERVE | WALK_IN | LEGACY_POS
  trustSignature String
  tableId        String
  customerRef    String?
  customerPhone  String?
  flavor         String?
  flavorMix      String? // JSON as string for SQLite compatibility
  loungeId       String  @default("default-lounge") // Required field with default
  priceCents     Int
  // Pricing / refill metadata
  sessionType    String?  @map("session_type") // TIME_BASED | FLAT
  hadRefill      Boolean  @default(false) @map("had_refill")
  refillCount    Int      @default(0) @map("refill_count")
  state          SessionState  @default(PENDING)
  edgeCase       String? // 'EQUIPMENT_ISSUE', 'CUSTOMER_NOT_FOUND', 'PAYMENT_FAILED', 'HEALTH_SAFETY', 'OTHER'
  edgeNote       String?
  assignedBOHId  String?
  assignedFOHId  String?
  startedAt      DateTime? // set when state -> ACTIVE
  endedAt        DateTime? // set when state -> COMPLETED/CANCELLED
  durationSecs   Int? // compute on complete
  paymentIntent  String? // Stripe PI id
  paymentStatus  String? // requires "succeeded" to complete
  orderItems     String? // JSON as string for SQLite compatibility
  posMode        String? // POS integration mode
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Timer fields
  timerDuration       Int? // in minutes
  timerStartedAt      DateTime?
  timerPausedAt       DateTime?
  timerPausedDuration Int? // total paused time in seconds
  timerStatus         String? // 'stopped' | 'running' | 'paused' | 'completed'

  // New fields for Pre-Order flow
  zone            String? // 'VIP', 'Standard', 'Patio', etc.
  fohUserId       String? // FOH staff assigned to this session
  specialRequests String? // Customer special requests
  tableNotes      String? // Notes specific to this table/session
  qrCodeUrl       String? // URL to QR code image/data URL for staff scanning (fraud prevention)

  // Taxonomy v1 fields (dual-write pattern)
  sessionStateV1  String? @map("session_state_v1") // Taxonomy v1: queued | prep | handoff | delivering | delivered | checkout | closed | canceled
  paused          Boolean @default(false) // PAUSED is a modifier flag, not a state

  // Multi-tenant field
  tenantId        String? @map("tenant_id") @db.Uuid

  // Relations
  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  payments Payment[] // One session can have multiple payments

  @@index([tenantId])
  @@map("Session")
}

// Partnership Models
model Partner {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  tier      String   @default("bronze") // bronze|silver|gold|platinum
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  referrals Referral[]
  payouts   Payout[]
  stats     PartnerStats?

  @@map("partners")
}

model PartnerStats {
  id               String   @id @default(cuid())
  partnerId        String   @unique
  totalReferrals   Int      @default(0)
  activeLounges    Int      @default(0)
  referralsLast30d Int      @default(0)
  qualityScore     Float    @default(0.0)
  lastUpdated      DateTime @default(now())

  // Relations
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_stats")
}

model Referral {
  id          String    @id @default(cuid())
  code        String    @unique
  partnerId   String
  loungeId    String?
  isActive    Boolean   @default(true)
  uses        Int       @default(0)
  maxUses     Int?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  activatedAt DateTime?

  // Relations
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("referrals")
}

model Payout {
  id          String    @id @default(cuid())
  partnerId   String
  period      String // e.g., "2025-01"
  gross       Float
  revSharePct Float
  net         Float
  status      String    @default("pending") // pending|paid
  createdAt   DateTime  @default(now())
  paidAt      DateTime?

  // Relations
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

// Enums replaced with string fields for SQLite compatibility

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  roles     String // Comma-separated roles: "BOH,FOH,MANAGER,ADMIN" (legacy, use memberships for multi-tenant)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Note: memberships.user_id references auth.users(id) from Supabase Auth
// Prisma cannot directly reference auth.users, so Membership model has userId field without relation

// Multi-tenant models
model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  memberships Membership[]
  sessions     Session[]
  events       ReflexEvent[]
  payments     Payment[]

  @@map("tenants")
}

model Membership {
  userId    String   @map("user_id") @db.Uuid // References auth.users(id) from Supabase Auth
  tenantId  String   @map("tenant_id") @db.Uuid
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  // Note: userId references auth.users(id), not User model (Prisma cannot reference auth schema)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([role])
  @@map("memberships")
}

model Payment {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id") @db.Uuid
  sessionId      String?   @map("session_id")
  stripeChargeId String?   @unique @map("stripe_charge_id")
  amountCents    Int       @map("amount_cents")
  status         String    @default("pending") // 'pending', 'succeeded', 'failed', 'refunded'
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  // Note: sessionId is not unique - a session can have multiple payments (refunds, partial payments, etc.)
  // So this is a one-to-many relation (one session can have many payments)

  @@index([tenantId])
  @@index([sessionId])
  @@index([stripeChargeId])
  @@index([status])
  @@index([paidAt])
  @@index([createdAt])
  @@map("payments")
}

model SessionTransition {
  id         String   @id @default(cuid())
  sessionId  String
  fromState  String
  toState    String
  transition String
  userId     String
  note       String?
  createdAt  DateTime @default(now())

  @@map("session_transitions")
}

model OrgSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String? // 'pos', 'menu', 'timing', 'ui'
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("org_settings")
}

model Category {
  id           String   @id @default(cuid())
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  icon         String? // Icon name or URL
  color        String? // Hex color code
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  items Item[]

  @@map("categories")
}

model Item {
  id           String   @id @default(cuid())
  name         String
  description  String?
  priceCents   Int
  categoryId   String
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  imageUrl     String?
  allergens    String // Comma-separated allergen strings
  isPopular    Boolean  @default(false)
  prepTime     Int? // Prep time in minutes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  category Category @relation(fields: [categoryId], references: [id])

  @@map("items")
}

model ReflexEvent {
  id            String   @id @default(cuid())
  type          String
  source        String   @default("ui") // ui | backend | agent
  sessionId     String? // lounge session id (if any)
  paymentIntent String? // stripe PI (if any)
  payload       String? // JSON string for SQLite compatibility
  payloadHash   String? // SHA256 hash for deduplication
  userAgent     String?
  ip            String?
  createdAt     DateTime @default(now())
  
  // CTA Tracking Fields
  ctaSource     String? // 'website' | 'instagram' | 'linkedin' | 'email' | 'calendly'
  ctaType       String? // 'demo_request' | 'onboarding_signup' | 'contact_form' | 'social_click'
  referrer      String? // HTTP referrer or social media referrer
  campaignId    String? // Marketing campaign identifier
  metadata      String? // Additional JSON metadata for source-specific data

  // Taxonomy v1 fields (dual-write pattern)
  trustEventTypeV1 String? // Taxonomy v1: on_time_delivery | fav_used | fast_checkout | corrected_issue | staff_greeting | loyalty_redeemed

  // Multi-tenant field
  tenantId        String? @map("tenant_id") @db.Uuid

  // Relations
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([ctaSource])
  @@index([ctaType])
  @@index([campaignId])
  @@index([trustEventTypeV1])
  @@index([tenantId])
  @@map("reflex_events")
}

// KTL-4 Keep-The-Lights-On Models
model Ktl4HealthCheck {
  id          String   @id @default(cuid())
  flowName    String // 'payment_settlement', 'session_lifecycle', 'order_intake', 'pos_sync'
  checkType   String // 'heartbeat', 'reconciliation', 'latency', 'parity'
  status      String // 'healthy', 'degraded', 'critical', 'failed'
  details     String? // JSON string with check details
  threshold   Int? // Threshold that was checked
  actualValue Int? // Actual value that triggered status
  operatorId  String? // Operator who triggered manual check
  createdAt   DateTime @default(now())

  @@index([flowName, createdAt])
  @@map("ktl4_health_checks")
}

model SettlementReconciliation {
  id             String    @id @default(cuid())
  stripeChargeId String? // Stripe charge ID
  posTicketId    String? // POS ticket ID
  sessionId      String? // Associated session
  amount         Int? // Amount in cents
  status         String // 'pending', 'matched', 'orphaned', 'reconciled'
  mismatchReason String? // Reason for mismatch if any
  repairRunId    String? // ID of repair run that fixed it
  createdAt      DateTime  @default(now())
  reconciledAt   DateTime?

  @@index([stripeChargeId])
  @@index([posTicketId])
  @@index([status, createdAt])
  @@map("settlement_reconciliation")
}

model PosTicket {
  id             String   @id @default(cuid())
  ticketId       String   @unique // External POS ticket ID
  sessionId      String? // Associated session
  stripeChargeId String? // Associated Stripe charge
  amountCents    Int // Total amount in cents
  items          String? // JSON string of items
  taxes          Int? // Tax amount in cents
  tips           Int? // Tip amount in cents
  status         String // 'pending', 'paid', 'refunded', 'cancelled'
  posSystem      String // 'square', 'clover', 'toast'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ticketId])
  @@index([sessionId])
  @@index([stripeChargeId])
  @@map("pos_tickets")
}

model MenuFile {
  id           String    @id @default(uuid())
  leadId       String?   @map("lead_id") // Link to ReflexEvent (lead) - stored as string ID
  fileName     String    @map("file_name")
  fileUrl      String    @map("file_url") // Supabase storage URL
  fileType     String    @map("file_type") // "application/pdf" | "image/jpeg" | "image/png"
  fileSize     Int       @map("file_size") // bytes
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  processedAt  DateTime? @map("processed_at")
  status       String    @default("pending") // "pending" | "processing" | "extracted" | "failed" | "deleted"
  extractedData Json?    @map("extracted_data") // Menu/flavor data extracted by agent
  tenantId     String?   @map("tenant_id") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") // Soft delete for retention tracking

  @@index([leadId])
  @@index([status])
  @@index([tenantId])
  @@index([uploadedAt])
  @@map("menu_files")
}

model SessionHeartbeat {
  id            String   @id @default(cuid())
  sessionId     String
  stationId     String? // Physical station/table ID
  status        String // 'active', 'paused', 'stalled', 'completed'
  elapsedSecs   Int // Elapsed time in seconds
  remainingSecs Int? // Remaining time in seconds
  lastPing      DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([sessionId, lastPing])
  @@map("session_heartbeats")
}

model PricingLock {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  finalPriceCents Int // Final locked price
  priceHash       String // Hash of pricing components
  components      String? // JSON string of price components
  lockedAt        DateTime @default(now())
  operatorId      String? // Operator who locked pricing
  auditNote       String? // Manual override note if any

  @@index([sessionId])
  @@map("pricing_locks")
}

model Ktl4Alert {
  id             String    @id @default(cuid())
  priority       String // 'P1', 'P2', 'P3'
  flowName       String // Which KTL-4 flow
  alertType      String // Type of alert
  message        String // Alert message
  details        String? // JSON string with alert details
  status         String // 'active', 'acknowledged', 'resolved'
  acknowledgedBy String? // Operator who acknowledged
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([priority, status, createdAt])
  @@map("ktl4_alerts")
}

model BreakGlassAction {
  id         String    @id @default(cuid())
  actionType String // 'freeze_station', 'degraded_mode', 'manual_override'
  targetId   String? // Station/session ID affected
  operatorId String // Operator who took action
  reason     String // Reason for break-glass action
  details    String? // JSON string with action details
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([actionType, createdAt])
  @@map("break_glass_actions")
}

// Loyalty Ledger Models (Jules)
// Non-crypto loyalty system with ACID compliance
model LoyaltyAccount {
  id                 String   @id @default(cuid())
  customerId         String? // Customer reference (CUST-xxx format)
  customerPhone      String? // Customer phone number (normalized format)
  balanceCents       Int      @default(0) // Current balance in cents
  totalEarnedCents   Int      @default(0) // Lifetime earned credits
  totalRedeemedCents Int      @default(0) // Lifetime redeemed credits
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  transactions LoyaltyTransaction[]
  wallet       LoyaltyWallet?

  @@index([customerId])
  @@index([customerPhone])
  @@index([isActive, updatedAt])
  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id                 String   @id @default(cuid())
  accountId          String // Foreign key to LoyaltyAccount
  type               String // 'ISSUE' | 'REDEEM' | 'ADJUST'
  amountCents        Int // Transaction amount (positive for ISSUE, negative for REDEEM)
  balanceBeforeCents Int // Balance before transaction
  balanceAfterCents  Int // Balance after transaction
  source             String // 'POS' | 'MANUAL' | 'REFUND' | 'ADJUSTMENT'
  sessionId          String? // Associated session ID
  posTicketId        String? // Associated POS ticket ID
  stripeChargeId     String? // Associated Stripe charge ID
  metadata           String? // JSON string with additional transaction metadata
  version            Int      @default(1) // Optimistic locking version
  createdAt          DateTime @default(now())

  // Relations
  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([sessionId])
  @@index([posTicketId])
  @@index([type, createdAt])
  @@index([source, createdAt])
  @@map("loyalty_transactions")
}

model LoyaltyWallet {
  id                String   @id @default(cuid())
  accountId         String   @unique // Foreign key to LoyaltyAccount (1:1)
  balanceCents      Int      @default(0) // Cached balance for performance
  lastTransactionId String? // Last transaction ID (for cache invalidation)
  updatedAt         DateTime @updatedAt

  // Relations
  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("loyalty_wallets")
}

// Taxonomy v1 Models
model DriftEvent {
  id            String   @id @default(cuid())
  sessionId     String?
  driftReasonV1 String? // Taxonomy v1: slow_handoff | long_dwell | payment_retry | missing_notes | queue_backlog | no_show
  severity      String? // low | medium | high
  details       String? // JSON string
  createdAt     DateTime @default(now())

  @@index([driftReasonV1])
  @@index([sessionId])
  @@index([createdAt])
  @@map("DriftEvent")
}

model TaxonomyUnknown {
  id               String   @id @default(cuid())
  enumType         String // SessionState | TrustEventType | DriftReason
  rawLabel         String
  suggestedMapping String?
  count            Int      @default(1)
  exampleEventId   String?
  examplePayload   String? // JSON string
  firstSeen        DateTime @default(now())
  lastSeen         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([enumType, rawLabel])
  @@index([enumType])
  @@index([count])
  @@index([lastSeen])
  @@map("TaxonomyUnknown")
}
