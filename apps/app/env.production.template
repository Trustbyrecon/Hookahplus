# Hookah+ Production Environment Configuration
# Copy this to .env.production for production deployment
# Set these in Vercel → Settings → Environment Variables

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# STRIPE CONFIGURATION (LIVE MODE)
# ===========================================
STRIPE_SECRET_KEY=sk_live_your_live_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_your_live_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret

# ===========================================
# APPLICATION URLs
# ===========================================
NEXT_PUBLIC_SITE_URL=https://hookahplus.net
NEXT_PUBLIC_APP_URL=https://app.hookahplus.net
NEXT_PUBLIC_GUEST_URL=https://guest.hookahplus.net

# ===========================================
# FEATURE FLAGS
# ===========================================
NEXT_PUBLIC_PRETTY_THEME=1
NEXT_PUBLIC_ANALYTICS_ENABLED=1
NEXT_PUBLIC_DEBUG_MODE=0

# ===========================================
# MONITORING & LOGGING
# ===========================================
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# SECURITY
# ===========================================
NEXTAUTH_SECRET=your_nextauth_secret_key
NEXTAUTH_URL=https://app.hookahplus.net

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://username:password@host:port/database
DIRECT_URL=postgresql://username:password@host:port/database

# ===========================================
# EXTERNAL SERVICES
# ===========================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@hookahplus.net
SMTP_PASS=your-email-password

# ===========================================
# BACKUP & RECOVERY
# ===========================================
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key
BACKUP_RETENTION_DAYS=30
