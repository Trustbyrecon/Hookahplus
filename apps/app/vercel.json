{
  "version": 2,
  "buildCommand": "cd ../.. && cd apps/app && unset npm_config_workspace npm_config_workspaces npm_config_workspaces_enabled npm_config_user_agent && node scripts/prisma-generate.mjs && npx next build && node scripts/generate-sitemap.js",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm ci --include=dev --omit=optional",
  "ignoreCommand": "exit 1",
  "env": {
    "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1",
    "NEXT_PUBLIC_CLARITY_THRESHOLD": "0.98",
    "NEXT_PUBLIC_RESONANCE_FIELD": "soft-gold-on-obsidian",
    "NEXT_PUBLIC_SYMBOLIC_MARK": "Open-Gate-Phi",
    "NEXT_PUBLIC_HARMONIC_SIGNATURE": "Delta-A7"
  },
  "functions": {
    "app/**/*.ts": {
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/square/process?limit=250",
      "schedule": "*/5 * * * *"
    }
  ]
}
