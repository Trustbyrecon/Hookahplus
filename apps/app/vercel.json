{
  "version": 2,
  "builds": [
    {
      "src": "apps/app/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": "apps/app/.next"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/apps/app/$1"
    }
  ],
  "functions": {
    "apps/app/app/api/payments/live-test/route.ts": {
      "maxDuration": 30
    },
    "apps/app/app/api/stripe-health/route.ts": {
      "maxDuration": 15
    },
    "apps/app/app/api/stripe/webhook/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "apps/app/app/api/square/webhook/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "apps/app/app/api/**/route.ts": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/feat-guests-cart/:path*",
      "destination": "https://hookahplus-app-prod.vercel.app/:path*",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://hookahplus-app-prod.vercel.app",
    "NEXT_PUBLIC_GUEST_URL": "https://guest.hookahplus.net",
    "NEXT_PUBLIC_SITE_URL": "https://hookahplus.net"
  }
}