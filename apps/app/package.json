{
  "name": "@hookahplus/app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "scripts": {
    "dev": "next dev --port 3002",
    "dev:default": "next dev",
    "build": "node scripts/prisma-generate.mjs && next build && node scripts/generate-sitemap.js",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/prisma-generate.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:status": "prisma migrate status",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "test:square": "tsx scripts/test-square-integration.ts",
    "test:square:oauth": "tsx scripts/test-square-integration.ts --oauth",
    "test:square:oauth:probe": "tsx scripts/test-square-integration.ts --oauth --probe",
    "test:square:smoke:oauth": "npm run test:square:oauth",
    "test:square:smoke:oauth:aliethia": "npm run test:square:oauth -- Aliethia",
    "test:square:smoke:oauth:aliethia:sandbox": "npm run test:square:oauth -- AliethiaSandbox",
    "test:square:smoke:oauth:probe:aliethia": "npm run test:square:oauth:probe -- Aliethia",
    "test:square:smoke:oauth:probe:aliethia:sandbox": "npm run test:square:oauth:probe -- AliethiaSandbox",
    "test:pos": "tsx scripts/test-square-integration.ts",
    "debug:square": "tsx scripts/debug-square-token.ts",
    "verify:square": "tsx scripts/verify-square-oauth-setup.ts",
    "pos:square:pull:tickets": "tsx scripts/pull-square-tickets.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@sentry/nextjs": "10.30.0",
    "@stripe/react-stripe-js": "^4.0.2",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/ssr": "0.7.0",
    "@supabase/supabase-js": "2.83.0",
    "@types/ioredis": "4.28.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vercel/kv": "3.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "17.2.3",
    "framer-motion": "12.23.24",
    "ioredis": "5.8.2",
    "lucide-react": "^0.263.1",
    "next": "14.2.7",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "3.3.0",
    "resend": "6.4.2",
    "stripe": "^18.5.0",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-react": "5.31.0",
    "swr": "^2.2.4",
    "tailwind-merge": "^2.6.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/pg": "8.15.6",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.7",
    "jsdom": "^27.0.0",
    "pg": "8.16.3",
    "postcss": "^8.4.0",
    "tailwindcss": "3.4.17",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
