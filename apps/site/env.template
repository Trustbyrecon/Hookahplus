NEXT_PUBLIC_CLARITY_METRICS_ENABLED=true

# === EMAIL SERVICE (RESEND) ===
# Resend email service configuration for transactional emails

# Resend API Key (get from https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From email address (use onboarding@resend.dev for testing, or verified domain for production)
RESEND_FROM_EMAIL=Hookah+ <noreply@hookahplus.net>

# === STRIPE (SUBSCRIPTIONS / PRICING CHECKOUT) ===
# Required for `/pricing` -> "Continue to Checkout" (POST /api/subscribe)
#
# You can use LIVE keys in production, and TEST keys locally or for preview.
# The server will use STRIPE_SECRET_KEY if present, otherwise STRIPE_TEST_SECRET_KEY.

# One of these must be set:
STRIPE_SECRET_KEY=sk_live_...
STRIPE_TEST_SECRET_KEY=sk_test_...

# Optional (used by other flows/UI widgets if enabled)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_TEST_MODE=false

# --- Tier subscription prices (Stripe Price IDs: price_...) ---
# Monthly
PRICE_TIER_STARTER=price_...
PRICE_TIER_PRO=price_...
PRICE_TIER_TRUST_PLUS=price_...

# Annual (optional; if missing, API falls back to monthly)
PRICE_TIER_STARTER_ANNUAL=price_...
PRICE_TIER_PRO_ANNUAL=price_...
PRICE_TIER_TRUST_PLUS_ANNUAL=price_...

# --- Add-on prices (optional; only needed if add-ons are enabled/selected) ---
PRICE_ADDON_FLAVOR_INTELLIGENCE=price_...
PRICE_ADDON_ADVANCED_ANALYTICS=price_...
PRICE_ADDON_STAFF_PERFORMANCE=price_...
PRICE_ADDON_CUSTOM_INTEGRATIONS=price_...
PRICE_ADDON_AGENTIC_COMMERCE=price_...
PRICE_ADDON_AGENTIC_COMMERCE_USAGE=price_...
PRICE_ADDON_PRIORITY_SUPPORT=price_...

# Annual add-ons (optional)
PRICE_ADDON_FLAVOR_INTELLIGENCE_ANNUAL=price_...
PRICE_ADDON_ADVANCED_ANALYTICS_ANNUAL=price_...
PRICE_ADDON_STAFF_PERFORMANCE_ANNUAL=price_...
