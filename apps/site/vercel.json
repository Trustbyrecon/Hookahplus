{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm build --filter=@hookahplus/site",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/site/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
