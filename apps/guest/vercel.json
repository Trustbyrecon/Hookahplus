{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm build --filter=@hookahplus/guest",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "apps/guest/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
