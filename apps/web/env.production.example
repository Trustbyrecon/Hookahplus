# Production Environment Variables for Hookah+

# Stripe Configuration (Live Mode)
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_LIVE_STRIPE_WEBHOOK_SECRET

# Trust-Lock Security
TRUSTLOCK_SECRET=YOUR_UNIQUE_TRUSTLOCK_SECRET_32_CHARS_OR_MORE

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Public Site URL
NEXT_PUBLIC_SITE_URL=https://hookahplus.net

# Google Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
