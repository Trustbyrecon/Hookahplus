# Toast POS Integration Environment Configuration
# Copy this file to .env.local and fill in your actual values

# Toast Configuration (Phase 2 - Partner API)
TOAST_BASE_URL=https://api.toasttab.com
TOAST_API_KEY=your_toast_partner_api_key_here
TOAST_RESTAURANT_GUID=your_restaurant_guid_here
TOAST_WEBHOOK_SECRET=your_webhook_secret_here

# Toast Development/Testing
# TOAST_BASE_URL=https://ws-api.toasttab.com  # Sandbox URL
# TOAST_API_KEY=sandbox_api_key_here
# TOAST_RESTAURANT_GUID=sandbox_restaurant_guid_here

# Trust-Lock Security (shared with other POS providers)
TRUSTLOCK_SECRET=super-long-random-string-here

# Optional: Override defaults for testing
# TOAST_ENV=sandbox
# TOAST_DEBUG=true
