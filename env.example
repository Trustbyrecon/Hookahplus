# Hookah+ MVP Launch Environment Variables
# Copy this to .env.local for local development
# Set these in Vercel → Settings → Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Stripe Configuration (SANDBOX MODE - Use test keys to reduce costly errors)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (after running npm run seed:stripe)
PRICE_SESSION_30=price_your_session_30_price_id_here
PRICE_FLAVOR_150=price_your_flavor_150_price_id_here
PRICE_TIER_STARTER=price_your_starter_monthly_price_id_here
PRICE_TIER_STARTER_ANNUAL=price_your_starter_annual_price_id_here
PRICE_TIER_PRO=price_your_pro_monthly_price_id_here
PRICE_TIER_PRO_ANNUAL=price_your_pro_annual_price_id_here
PRICE_TIER_TRUST_PLUS=price_your_trust_plus_monthly_price_id_here
PRICE_TIER_TRUST_PLUS_ANNUAL=price_your_trust_plus_annual_price_id_here

# Stripe Add-on Price IDs (after running npm run seed:stripe)
PRICE_ADDON_FLAVOR_INTELLIGENCE=price_your_flavor_intelligence_monthly_price_id_here
PRICE_ADDON_FLAVOR_INTELLIGENCE_ANNUAL=price_your_flavor_intelligence_annual_price_id_here
PRICE_ADDON_ADVANCED_ANALYTICS=price_your_advanced_analytics_monthly_price_id_here
PRICE_ADDON_ADVANCED_ANALYTICS_ANNUAL=price_your_advanced_analytics_annual_price_id_here
PRICE_ADDON_STAFF_PERFORMANCE=price_your_staff_performance_monthly_price_id_here
PRICE_ADDON_STAFF_PERFORMANCE_ANNUAL=price_your_staff_performance_annual_price_id_here
PRICE_ADDON_CUSTOM_INTEGRATIONS=price_your_custom_integrations_monthly_price_id_here
PRICE_ADDON_CUSTOM_INTEGRATIONS_ANNUAL=price_your_custom_integrations_annual_price_id_here
PRICE_ADDON_PRIORITY_SUPPORT=price_your_priority_support_monthly_price_id_here
PRICE_ADDON_PRIORITY_SUPPORT_ANNUAL=price_your_priority_support_annual_price_id_here

# HookahPlus Reservation System
PRICE_ID_DEPOSIT_10=price_your_deposit_10_price_id_here
PRICE_ID_BRONZE_200=price_your_bronze_200_price_id_here
PRICE_ID_EXTRA_HOOKAH_30=price_your_extra_hookah_30_price_id_here

# Trust-Lock Security
TRUSTLOCK_SECRET=your_super_long_random_string_here_minimum_32_chars

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ManyChat Integration
MANYCHAT_WEBHOOK_SECRET=your_manychat_webhook_secret_here
MANYCHAT_VERIFY_TOKEN=hookahplus_manychat_verify

# Webhook API Key (for internal webhook calls to bypass auth in production)
WEBHOOK_API_KEY=your_secure_webhook_api_key_here_minimum_32_chars

# Calendly Integration
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/clark-dwayne/new-meeting

# First Light Mode (bypasses auth for /api/sessions and /api/metrics when set to 'true')
# Use this during initial setup to test core engine without authentication
FIRST_LIGHT_MODE=false

# Node Version (for Vercel)
NODE_VERSION=20
