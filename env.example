# Hookah+ MVP Launch Environment Variables
# Copy this to .env.local for local development
# Set these in Vercel → Settings → Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Stripe Configuration (SANDBOX MODE - Use test keys to reduce costly errors)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (after running npm run seed:stripe)
PRICE_SESSION_30=price_your_session_30_price_id_here
PRICE_FLAVOR_150=price_your_flavor_150_price_id_here
PRICE_TIER_STARTER=price_your_starter_99_price_id_here
PRICE_TIER_PRO=price_your_pro_249_price_id_here
PRICE_TIER_TRUST_PLUS=price_your_trust_plus_499_price_id_here

# HookahPlus Reservation System
PRICE_ID_DEPOSIT_10=price_your_deposit_10_price_id_here
PRICE_ID_BRONZE_200=price_your_bronze_200_price_id_here
PRICE_ID_EXTRA_HOOKAH_30=price_your_extra_hookah_30_price_id_here

# Trust-Lock Security
TRUSTLOCK_SECRET=your_super_long_random_string_here_minimum_32_chars

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Node Version (for Vercel)
NODE_VERSION=20
