{
  "name": "hookahplus-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx prisma generate && next build",
    "build:vercel": "npm install && npx prisma generate && next build",
    "build:site": "cd apps/site && npm install && npm run build",
    "build:app": "cd apps/app && npm install && npm run build",
    "dev": "next dev",
    "dev:all": "concurrently \"npm run dev:guest\" \"npm run dev:app\" \"npm run dev:site\"",
    "dev:guest": "cd apps/guest && npm run dev",
    "dev:app": "cd apps/app && npm run dev",
    "dev:site": "cd apps/site && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:web:legacy": "cd apps/web && npm run dev",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next",
    "stripe:seed": "node scripts/stripe-catalog/seed.js",
    "seed:stripe": "node scripts/seed-stripe-subscriptions.js",
    "reflex:smoke": "tsx scripts/reflex-smoke.ts",
    "cmd:test:sync:golden": "tsx scripts/cmd.test.sync.guestToApp.golden.ts",
    "cmd:test:sync:faults": "tsx scripts/cmd.test.sync.guestToApp.faults.ts",
    "cmd:sync:inspect": "echo 'Open /admin/sync in your browser'",
    "db:migrate:app": "cd apps/app && npx prisma migrate deploy",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test": "npm --workspace @hookahplus/app run test",
    "test:sync:all": "npm run cmd:test:sync:golden && npm run cmd:test:sync:faults",
    "reflex:ci": "tsx scripts/reflex-smoke.ts --ci",
    "test:smoke": "playwright test --grep @smoke",
    "test:webhook": "playwright test tests/smoke/webhook-flow.spec.ts",
    "test:live-dollar": "playwright test tests/smoke/checkout-flow.spec.ts",
    "test:square": "npm --prefix integrations test",
    "test:square:smoke": "cd apps/app && npm run test:square",
    "test:square:smoke:oauth": "cd apps/app && npm run test:square:oauth",
    "test:square:smoke:aliethia": "cd apps/app && npm run test:square -- Aliethia",
    "test:square:smoke:oauth:aliethia": "cd apps/app && npm run test:square:oauth -- Aliethia",
    "test:square:smoke:oauth:aliethia:sandbox": "cd apps/app && npm run test:square:oauth -- AliethiaSandbox",
    "test:pos": "cd apps/app && npm run test:pos",
    "check:env-parity": "node scripts/check-env-parity.js",
    "reflex:gate": "node scripts/reflex-gate.js",
    "reflex:score": "node scripts/reflex-score.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "cypress": "13.17.0",
    "js-yaml": "^4.1.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.20.6",
    "turbo": "^2.0.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@stripe/stripe-js": "^2.4.0",
    "@types/qrcode": "1.5.5",
    "dotenv": "^17.2.2",
    "lucide-react": "^0.263.1",
    "next": "14.2.7",
    "qrcode": "1.5.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^2.8.0",
    "stripe": "^14.21.0",
    "zod": "^3.22.4"
  },
  "overrides": {
    "eslint": "8.57.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
