{
  "name": "hookahplus-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:site": "cd apps/site && pnpm build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "stripe:seed": "node scripts/stripe-catalog/seed.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^2.0.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "dotenv": "^17.2.2",
    "stripe": "^14.21.0"
  }
}