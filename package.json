{
  "name": "hookahplus-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx prisma generate && next build",
    "build:vercel": "pnpm install --no-frozen-lockfile && npx prisma generate && next build",
    "build:site": "cd apps/site && pnpm install --no-frozen-lockfile && pnpm run build",
    "build:app": "pnpm --filter @hookahplus/app run build",
    "vercel-build": "pnpm install --no-frozen-lockfile && pnpm --filter @hookahplus/app run build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next",
    "stripe:seed": "node scripts/stripe-catalog/seed.js",
    "reflex:smoke": "tsx scripts/reflex-smoke.ts",
    "reflex:ci": "tsx scripts/reflex-smoke.ts --ci",
    "test:smoke": "playwright test --grep @smoke",
    "test:webhook": "playwright test tests/smoke/webhook-flow.spec.ts",
    "test:live-dollar": "playwright test tests/smoke/checkout-flow.spec.ts",
    "check:env-parity": "node scripts/check-env-parity.js",
    "reflex:gate": "node scripts/reflex-gate.js",
    "reflex:score": "node scripts/reflex-score.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "js-yaml": "^4.1.0",
    "prisma": "^5.22.0",
    "turbo": "^2.0.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@stripe/stripe-js": "^2.4.0",
    "dotenv": "^17.2.2",
    "lucide-react": "^0.263.1",
    "next": "14.2.7",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^2.8.0",
    "stripe": "^14.21.0",
    "zod": "^3.22.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}