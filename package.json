{
  "name": "hookahplus-monorepo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^5.7.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "prisma": "^5.7.1",
    "ts-node": "^10.9.2",
    "turbo": "2.0.6"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
