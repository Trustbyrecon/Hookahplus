generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Badge {
  id     String  @id
  label  String
  scope  String  // 'lounge' | 'network'
  rule   String  // JSON as string for SQLite compatibility
  active Boolean @default(true)
  awards Award[]
}

model Award {
  id         String   @id
  profileId  String
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  venueId    String?
  progress   Int      @default(100)
  awardedAt  DateTime @default(now())
  awardedBy  String?
  revoked    Boolean  @default(false)

  @@index([profileId, badgeId, venueId, revoked])
}

model Event {
  id        String   @id @default(cuid())
  ts        DateTime @default(now())
  type      String   // 'check_in' | 'visit_closed' | 'mix_ordered'
  profileId String
  venueId   String?
  comboHash String?
  staffId   String?

  @@index([profileId])
  @@index([profileId, venueId])
}

model Session {
  id           String   @id @default(cuid())
  externalRef  String?  // qrToken | reservationId | stripeCheckoutId
  source       String   // QR | RESERVE | WALK_IN
  trustSignature String
  state        String   @default("PENDING") // PENDING | ACTIVE | PAUSED | CLOSED | CANCELED
  customerPhone String?
  flavorMix    String?  // JSON as string for SQLite compatibility
  loungeId     String
  tableId      String?  // Table identifier for the session
  version      Int @default(1)
  edgeCase     String?  // Edge case identifier
  edgeNote     String?  // Edge case description
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  events       SessionEvent[]
  transitions  SessionTransition[]

  @@index([loungeId, state])
  @@index([loungeId, tableId])
  @@unique([loungeId, externalRef]) // idempotent anchor
}

model SessionEvent {
  id          String   @id @default(cuid())
  sessionId   String
  type        String
  payloadSeal String
  data        String   // JSON as string for SQLite compatibility
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model SessionTransition {
  id          String   @id @default(cuid())
  sessionId   String
  fromState   String
  toState     String
  transition  String
  userId      String?  // User who triggered the transition
  note        String?  // Additional notes about the transition
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model ReflexEvent {
  id            String    @id @default(cuid())
  type          String
  source        String    @default("ui")
  sessionId     String?
  paymentIntent String?
  payload       String?   // JSON as string for SQLite compatibility
  payloadHash   String?
  userAgent     String
  ip            String
  createdAt     DateTime  @default(now())

  @@index([type, createdAt])
  @@index([ip, type, payloadHash, createdAt])
}

model SettlementReconciliation {
  id              String   @id @default(cuid())
  stripeChargeId  String?  // Stripe charge ID
  posTicketId     String?  // POS ticket ID
  sessionId       String?  // Session ID
  amount          Int?     // Amount in cents
  currency        String?  // Currency code
  status          String   @default("pending") // pending, matched, orphaned
  matchedAt       DateTime?
  reconciledAt    DateTime? // When reconciliation was completed
  repairRunId     String?  // Repair run identifier
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([stripeChargeId])
  @@index([posTicketId])
  @@index([sessionId])
}

model PosTicket {
  id              String   @id @default(cuid())
  ticketId        String   // POS system ticket ID
  stripeChargeId  String?  // Associated Stripe charge ID
  sessionId       String?  // Associated session ID
  amount          Int?     // Amount in cents
  currency        String?  // Currency code
  status          String   @default("pending") // pending, paid, refunded
  posSystem       String?  // POS system identifier
  items           String?  // JSON string of items
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ticketId])
  @@index([stripeChargeId])
  @@index([sessionId])
  @@index([status])
}